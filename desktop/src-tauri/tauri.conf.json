{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mPM",
  "version": "0.1.0",
  "identifier": "me.arneman.mpm",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "mPM",
        "width": 1200,
        "height": 800,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
