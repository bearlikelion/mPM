{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "bearlikelion/mpm",
    "type": "project",
    "description": "Active-development, self-hosted project management for organizations, projects, kanban, sprint planning, notifications, and YAML scaffolding.",
    "keywords": ["project-management", "self-hosted", "kanban", "sprint-planning", "laravel", "livewire", "filament"],
    "license": "proprietary",
    "authors": [
        {
            "name": "Mark Arneman"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "intervention/image-laravel": "^4.0",
        "laravel/framework": "^13.0",
        "laravel/reverb": "^1.0",
        "laravel/socialite": "^5.26",
        "laravel/tinker": "^3.0",
        "livewire/flux": "^2.0",
        "livewire/livewire": "^4.2",
        "livewire/volt": "^1.6.7",
        "robsontenorio/mary": "^2.0",
        "socialiteproviders/discord": "^4.2",
        "socialiteproviders/steam": "^4.3",
        "spatie/laravel-medialibrary": "^11.21",
        "spatie/laravel-permission": "^7.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "mpm": {
            "status": "active-development",
            "license_intent": "copyleft self-hosted source-available license",
            "commercial_service_restriction": "You may not use this code to create, operate, resell, or host a paid project-management service or SaaS offering."
        },
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
